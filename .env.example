# OpenRouter API Key (recommended — access all providers via one key)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# xAI API Key (default provider)
XAI_API_KEY=your_api_key_here

# Optional: Anthropic API Key (if using Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: OpenAI API Key (if using OpenAI models)
# OPENAI_API_KEY=your_openai_api_key

# Optional: Google AI API Key (if using Gemini models)
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key

# Optional: Custom Convex URL
# STRUERE_CONVEX_URL=https://struere.convex.cloud
